# ═══════════════════════════════════════════════════════════
# NeuroCI — Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── LLM Provider (choose one: gemini, groq, ollama, openai) ──
LLM_PROVIDER=gemini

# ── Google Gemini (FREE — recommended) ──
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy_your_gemini_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# ── Groq (FREE tier — fast inference) ──
# Get your free key at: https://console.groq.com/keys
# GROQ_API_KEY=gsk_your_groq_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Ollama (FREE — runs 100% locally, no API key!) ──
# Install: https://ollama.com  →  ollama pull llama3.1
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── OpenAI (paid) ──
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── GitHub ──
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
GITHUB_ALLOWED_REPOS=owner/repo1,owner/repo2

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── ChromaDB ──
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=neuroci_fixes

# ── Slack (optional) ──
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL=#neuroci-alerts

# ── OPA ──
OPA_URL=http://localhost:8181
OPA_POLICY_PATH=v1/data/neuroci/allow

# ── NeuroCI Settings ──
NEUROCI_CONFIDENCE_THRESHOLD=0.85
NEUROCI_MAX_PATCH_LINES=20
NEUROCI_MAX_LOG_TOKENS=8000
NEUROCI_RESTRICTED_PATHS=infra/,terraform/,secrets.py,auth.py,.env

# ── Observability ──
LOG_LEVEL=INFO
PROMETHEUS_PORT=9090

# ── LangSmith (optional) ──
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LANGCHAIN_PROJECT=neuroci
